{
  "name": "courtcare",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered sports coach for court sports. Real-time pose tracking and form analysis.",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@courtcare/web",
    "dev:api": "turbo dev --filter=@courtcare/api",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "deploy": "turbo deploy",
    "deploy:api": "turbo deploy --filter=@courtcare/api",
    "deploy:web": "turbo deploy --filter=@courtcare/web",
    "db:migrate:local": "pnpm --filter @courtcare/api db:migrate:local",
    "db:migrate:remote": "pnpm --filter @courtcare/api db:migrate:remote",
    "db:seed:local": "pnpm --filter @courtcare/api db:seed:local",
    "db:seed:remote": "pnpm --filter @courtcare/api db:seed:remote"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0"
}
