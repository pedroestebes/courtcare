{
  "name": "@courtcare/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply courtcare-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply courtcare-db --remote",
    "db:seed:local": "wrangler d1 execute courtcare-db --local --file=src/db/seed.sql",
    "db:seed:remote": "wrangler d1 execute courtcare-db --remote --file=src/db/seed.sql"
  },
  "dependencies": {
    "@courtcare/shared": "workspace:*",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.99.0"
  }
}
